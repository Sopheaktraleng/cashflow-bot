{
    "name": "cashflow-bot",
    "version": "2.0.0",
    "description": "Telegram cashflow bot hosted on Cloudflare Workers and D1.",
    "type": "module",
    "main": "src/worker.js",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate:local": "wrangler d1 execute cashflow_bot --local --file=./schema.sql",
        "db:migrate:remote": "wrangler d1 execute cashflow_bot --remote --file=./schema.sql",
        "set:webhook": "node scripts/set-webhook.js"
    },
    "keywords": [
        "telegram",
        "bot",
        "cloudflare-workers",
        "d1"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "wrangler": "^4.20.3"
    }
}
